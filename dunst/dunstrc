[global]
    enable_recursive_icon_lookup = false
    icon_position = off
    notification_limit = 0
    monitor = 0
    follow = mouse
    width = 450
    height = 300
    origin = top-center
    offset = 0x50
    gap_size = 6
    padding = 12
    horizontal_padding = 14
    frame_width = 2
    separator_height = 2
    font = JetBrainsMono Nerd Font 15
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    stack_duplicates = true
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    corner_radius = 8
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1a1a1a"
    foreground = "#e5e0d8"
    frame_color = "#333333"
    timeout = 4

[urgency_normal]
    background = "#1a1a1a"
    foreground = "#e5e0d8"
    frame_color = "#c45c26"
    timeout = 8
    script = "/home/pibaao/dot_files/scripts/notify-sound.sh"

[urgency_critical]
    background = "#c45c26"
    foreground = "#e5e0d8"
    frame_color = "#ff6b35"
    timeout = 0

[slack]
    appname = Slack
    timeout = 10
    urgency = normal

[discord]
    appname = discord
    timeout = 10
    urgency = normal

[fullscreen_delay_everything]
    fullscreen = delay
